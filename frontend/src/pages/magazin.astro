---
import Layout from '../layouts/Layout.astro';
import data from '../../public/data.json';
import '../../assets/scss/astro-ecommerce.scss';
import Navbar from '../components/navbar';
import CategoryFilter from '../components/products/categoryFilters';
import CardProduct from '../components/products/cardProduct';

// Pagination settings
const productsPerPage = 2500; // Set the number of products per page
let totalPages = Math.ceil(data.products.length / productsPerPage); // Calculate total pages

let currentPage = 1;

// State for filtered products (Initially set to all products)
let filteredProducts = data.products;

let paginatedProducts = filteredProducts.slice(0, productsPerPage);

// Function to filter products from API
async function filterProducts(category) {
  try {
    const response = await fetch(`/backend/products/filter?category=${category}`);
    if (response.ok) {
      const data = await response.json();
      filteredProducts = data;
      totalPages = Math.ceil(filteredProducts.length / productsPerPage); // Update total pages
      currentPage = 1; // Reset to the first page
      paginatedProducts = filteredProducts.slice(0, productsPerPage);
      updatePagination();
    } else {
      console.error("Error fetching filtered products:", response.statusText);
    }
  } catch (error) {
    console.error("Error filtering products:", error);
  }
}

// Function to update pagination based on filtered products
function updatePagination() {
  const startIndex = (currentPage - 1) * productsPerPage;
  paginatedProducts = filteredProducts.slice(startIndex, startIndex + productsPerPage);
}

// Function to handle pagination controls
function handlePaginationChange(page) {
  currentPage = page;
  updatePagination();
}

---

<Layout title="Magazin mobila la comanda Barlad">
  <main>
    <Navbar />
    <div class="container mt-5">
      <div class="row">
        <h5 class="mb-4">Customers also purchased</h5>
        {paginatedProducts.map(product => 
          <div class="col-md-6 col-lg-3">
            <CardProduct 
              title={product.title}
              description={product.description}
              images={product.image_urls}
            />
          </div>
        )}
      </div>
    </div>
  
    
  </main>
</Layout>
