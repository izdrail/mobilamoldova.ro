---
// Types
export interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
}

// Props with defaults
const { 
  title, 
  description = "Mobila la comanda barlad. Explorează cea mai rafinată colecție de mobilier lucrat manual din Barlad.",
  canonicalUrl = "https://mobilamodova.ro/"
} = Astro.props;

// Environment variables
const isDevelopment = import.meta.env.DEV;
const gtmId = 'GTM-K2KSS7RX';

// Navigation items
const navigationItems = [
  ['Acasa', '/'],
  ['Magazin', '/magazin'],
  ['Dormitor', '/mobila-dormitor'],
  ['Sufragerie', '/mobila-sufragerie'],
  ['Paturi', '/paturi-la-comanda'],
  ['Dulapuri', '/dulapuri-la-comanda'],
  ['Recicleaza', '/recicleaza'],
  ['Support', '/support']
];
---

<!DOCTYPE html>
<html lang="ro" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    
    <!-- Favicon -->
    <link 
      rel="icon" 
      type="image/svg+xml" 
      href={`${import.meta.env.BASE_URL}favicon.svg`} 
    />
    
    <!-- Fonts -->
    <link 
      rel="preconnect" 
      href="https://fonts.googleapis.com" 
      crossorigin
    />
    <link 
      href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@300;400;600;700&family=Noto+Sans:wght@300;400;500;600;700;800&family=PT+Mono:wght@400&display=swap" 
      rel="stylesheet"
    />
    
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />

    <!-- Google Tag Manager -->
    {!isDevelopment && (
      <script define:vars={{ gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
  </head>
  <body class="h-full">
    <!-- Google Tag Manager (noscript) -->
    {!isDevelopment && (
      <noscript>
        <iframe 
          src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
          height="0" 
          width="0" 
          style="display:none;visibility:hidden"
        ></iframe>
      </noscript>
    )}

    <!-- Fixed Header -->
    <div class="w-full border border-gray-100 dark:border-gray-800 rounded-lg fixed top-0 z-50 bg-white dark:bg-gray-800">
      <header>
        <!-- Main Navigation -->
        <nav class="px-4 py-3 dark:border-gray-700 max-w-screen-2xl mx-auto">
          <div class="container mx-auto flex justify-between items-center">
            <!-- Logo -->
            <a href="/" class="flex items-center gap-3">
              <img 
                src="favicon.svg" 
                alt="Mobila Moldova Logo" 
                class="h-8 w-auto"
              />
              <span class="text-xl font-semibold dark:text-white">
                Mobila Moldova
              </span>
            </a>

            <!-- Contact -->
            <div class="flex items-center gap-6">
              <a 
                href="tel:+40412234" 
                class="hidden sm:inline text-sm font-medium text-gray-900 hover:text-primary-600 dark:text-white"
              >
                (+40) 412-1234
              </a>
              <a 
                href="/contact" 
                class="text-sm font-medium text-primary-600 hover:underline dark:text-white"
              >
                Contact
              </a>
            </div>
          </div>
        </nav>

        <!-- Secondary Navigation -->
        <nav class="bg-gray-50 dark:bg-gray-700 px-4 py-3">
          <div class="container mx-auto">
            <!-- Desktop Navigation -->
            <ul class="hidden lg:flex gap-8 text-sm font-medium">
              {navigationItems.map(([label, href]) => (
                <li>
                  <a 
                    href={href}
                    class="text-gray-700 hover:text-primary-600 dark:text-white dark:hover:text-primary-400 transition-colors"
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>

            <!-- Mobile Navigation -->
            <div class="flex lg:hidden items-center justify-between">
              <div class="flex gap-4">
                <a href="/" class="text-sm hover:underline dark:text-white">Acasa</a>
                <a href="/magazin" class="text-sm hover:underline dark:text-white">Magazin</a>
                <a href="/mobila-dormitor" class="text-sm hover:underline dark:text-white">Dormitor</a>
              </div>
              <button
                type="button"
                class="p-2 text-gray-500 hover:text-gray-600 dark:text-gray-400"
                aria-label="Deschide meniu"
              >
                <svg 
                  class="w-6 h-6" 
                  fill="none" 
                  stroke="currentColor" 
                  viewBox="0 0 24 24"
                >
                  <path 
                    stroke-linecap="round" 
                    stroke-linejoin="round" 
                    stroke-width="2" 
                    d="M4 6h16M4 12h16M4 18h16"
                  />
                </svg>
              </button>
            </div>
          </div>
        </nav>
      </header>
    </div>

    <!-- Main Content -->
    <main >
      <slot />
    </main>

    <!-- Scripts -->
    <script 
      src="https://kit.fontawesome.com/349ee9c857.js" 
      crossorigin="anonymous"
      defer
    ></script>
    
    <script 
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js" 
      integrity="sha384-geWF76RCwLtnZ8qwWowPQNguL3RmwHVBC9FhGdlKrxdiJJigb/j/68SIy3Te4Bkz" 
      crossorigin="anonymous"
      defer
    ></script>
    
    <script>
      import "/assets/js/astro-ecommerce.js"
    </script>
  </body>
</html>

<style is:global>
  /* Base styles */
  :root {
    --font-mono: Menlo, Monaco, 'Lucida Console', 'Liberation Mono', 
      'DejaVu Sans Mono', 'Bitstream Vera Sans Mono', 'Courier New', monospace;
  }

  /* Code blocks */
  code {
    font-family: var(--font-mono);
  }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    html {
      color-scheme: dark;
    }
  }

  /* Adjust for fixed header */
  body {
    padding-top: env(safe-area-inset-top);
  }
</style>